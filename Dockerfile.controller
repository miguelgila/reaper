# Multi-stage build for reaper-controller
# Produces a minimal static binary for Kubernetes Deployment.
# Supports multi-arch builds via docker buildx.

# --- Builder stages (cross-compile on native platform) ---
FROM --platform=$BUILDPLATFORM messense/rust-musl-cross:x86_64-musl AS builder-amd64
WORKDIR /work
COPY . .
RUN cargo build --release --features controller --bin reaper-controller --target x86_64-unknown-linux-musl && \
    cp target/x86_64-unknown-linux-musl/release/reaper-controller /reaper-controller

FROM --platform=$BUILDPLATFORM messense/rust-musl-cross:aarch64-musl AS builder-arm64
WORKDIR /work
COPY . .
RUN cargo build --release --features controller --bin reaper-controller --target aarch64-unknown-linux-musl && \
    cp target/aarch64-unknown-linux-musl/release/reaper-controller /reaper-controller

# --- Runtime stage ---
FROM gcr.io/distroless/static-debian12:nonroot
ARG TARGETARCH
COPY --from=builder-${TARGETARCH} /reaper-controller /usr/local/bin/reaper-controller
USER nonroot:nonroot
ENTRYPOINT ["/usr/local/bin/reaper-controller"]
