# Multi-stage build for reaper-agent
# Produces a minimal static binary for Kubernetes DaemonSet deployment.
# Supports multi-arch builds via docker buildx.

# --- Builder stages (cross-compile on native platform) ---
FROM --platform=$BUILDPLATFORM messense/rust-musl-cross:x86_64-musl AS builder-amd64
WORKDIR /work
COPY . .
RUN cargo build --release --features agent --bin reaper-agent --target x86_64-unknown-linux-musl && \
    cp target/x86_64-unknown-linux-musl/release/reaper-agent /reaper-agent

FROM --platform=$BUILDPLATFORM messense/rust-musl-cross:aarch64-musl AS builder-arm64
WORKDIR /work
COPY . .
RUN cargo build --release --features agent --bin reaper-agent --target aarch64-unknown-linux-musl && \
    cp target/aarch64-unknown-linux-musl/release/reaper-agent /reaper-agent

# --- Runtime stage ---
FROM gcr.io/distroless/static-debian12
ARG TARGETARCH
COPY --from=builder-${TARGETARCH} /reaper-agent /reaper-agent
ENTRYPOINT ["/reaper-agent"]
